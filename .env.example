# 自选股（必填）
STOCK_LIST=600519,000858,hk00700,AAPL,TSLA

# AI 模型（至少配置一个）
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.modelscope.cn/v1/
OPENAI_MODEL=openai/Qwen/Qwen2.5-72B-Instruct

# AlphaSift 开关（自动选策略，无需硬编码）
ALPHASIFT_ENABLED=true

# 数据源
TUSHARE_TOKEN=
DATA_SOURCE_PRIORITY=tickflow,akshare,tushare,baostock,yfinance

# QQ邮箱推送
EMAIL_SENDER=your@qq.com
EMAIL_PASSWORD=your_authorization_code
EMAIL_RECEIVERS=receiver@example.com

# 系统密钥（动态生成）
SECRET_KEY=